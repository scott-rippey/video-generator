{
  "name": "video-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Programmable video studio: brief to scenes.json to Remotion render",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "video": "tsx lib/orchestrator.ts",
